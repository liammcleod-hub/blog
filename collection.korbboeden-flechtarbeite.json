        "custom_liquid_UTWfAj": {
          "type": "custom-liquid",
          "name": "t:names.custom_liquid",
          "settings": {
            "custom_liquid": "{%- assign col = collection -%}\n{%- assign cat = col.metafields.custom.category.value -%}\n{%- if cat -%}\n  {%- comment %}Ascend to root category{%- endcomment -%}\n  {%- assign node = cat -%}\n  {%- for i in (1..10) -%}\n    {%- if node.parent -%}{%- assign node = node.parent.value -%}{%- else -%}{%- break -%}{%- endif -%}\n  {%- endfor -%}\n  {%- assign root = node -%}\n\n  <nav class=\"c-bc\" aria-label=\"Breadcrumb\">\n    <a href=\"{{ routes.root_url }}\">Home</a>\n    {%- comment %}Root link — use its first attached collection if present{%- endcomment -%}\n    {%- assign root_col = root.collections.value.first -%}\n    {%- if root_col -%}\n      <span>/</span><a href=\"{{ root_col.url }}\">{{ root.title }}</a>\n    {%- endif -%}\n\n    {%- comment %}If current category isn't the root, add it{%- endcomment -%}\n    {%- if cat.id != root.id -%}\n      {%- assign cat_col = cat.collections.value.first -%}\n      {%- if cat_col -%}\n        <span>/</span><a href=\"{{ cat_col.url }}\">{{ cat.title }}</a>\n      {%- endif -%}\n    {%- endif -%}\n\n    <span>/</span><span>{{ col.title }}</span>\n  </nav>\n{%- endif -%}"
          },
          "blocks": {}
        },
