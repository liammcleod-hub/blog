<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>



  <head>


    <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "s93cv4a5h6");
</script>


{% if template contains 'page' and page.handle == 'bastelbedarf' %}
  <title>Bastelbedarf – DIY‑Guide & Shop für Kreativprojekte</title>
  <meta name="description" content="Alles für dein Projekt: Farben, Kleber, Papiere, Werkzeuge & Bastelsets. Verständliche Anleitungen, Tipps & schnelle Lieferung aus Österreich.">
  <link rel="canonical" href="{{ shop.url }}/pages/bastelbedarf">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Bastelbedarf – DIY‑Guide & Shop für Kreativprojekte">
  <meta property="og:description" content="Alles für dein Projekt: Farben, Kleber, Papiere, Werkzeuge & Bastelsets. Verständliche Anleitungen, Tipps & schnelle Lieferung aus Österreich.">
  <meta property="og:url" content="{{ shop.url }}{{ page.url }}">
  <!-- Optional: upload a file named bastelbedarf-og.jpg in Shopify › Files -->
  <meta property="og:image" content="{{ 'bastelbedarf-og.jpg' | file_url }}">
  <meta property="og:image:alt" content="Bastelbedarf: DIY‑Guide mit Farben, Kleber, Papieren & Sets">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Bastelbedarf – DIY‑Guide & Shop für Kreativprojekte">
  <meta name="twitter:description" content="Alles für dein Projekt: Farben, Kleber, Papiere, Werkzeuge & Bastelsets. Verständliche Anleitungen, Tipps & schnelle Lieferung aus Österreich.">
  <meta name="twitter:image" content="{{ 'bastelbedarf-og.jpg' | file_url }}">

  <!-- Structured Data -->
  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"WebPage",
    "@id":"{{ shop.url }}{{ page.url }}#webpage",
    "url":"{{ shop.url }}{{ page.url }}",
    "name":"Bastelbedarf – DIY‑Guide & Shop für Kreativprojekte",
    "inLanguage":"de-AT",
    "description":"Alles für dein Projekt: Farben, Kleber, Papiere, Werkzeuge & Bastelsets. Verständliche Anleitungen, Tipps & schnelle Lieferung aus Österreich.",
    "isPartOf":{
      "@type":"WebSite",
      "@id":"{{ shop.url }}#website",
      "name":"{{ shop.name }}",
      "url":"{{ shop.url }}/"
    }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context":"https://schema.org",
    "@type":"BreadcrumbList",
    "@id":"{{ shop.url }}{{ page.url }}#breadcrumbs",
    "itemListElement":[
      { "@type":"ListItem","position":1,"name":"Home","item":"{{ shop.url }}/" },
      { "@type":"ListItem","position":2,"name":"Bastelbedarf","item":"{{ shop.url }}{{ page.url }}" }
    ]
  }
  </script>
{% endif %}



{%- if request.page_type == 'collection' and collection and collection.image -%}
  {%- assign hero = collection.image -%}
  <link
    rel="preload"
    as="image"
    href="{{ hero | image_url: width: 1600 }}"
    imagesrcset="{{ hero | image_srcset }}"
    imagesizes="(min-width: 990px) 1200px, 100vw"
    fetchpriority="high">
{%- endif -%}


    {%- render 'stylesheets' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >

    {%- render 'meta-tags' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% render 'rapid-search-settings' %}
</head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}"><main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main></body>
</html>
