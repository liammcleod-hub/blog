          "settings": {
            "custom_liquid": "<div class=\"catalog-tight-container\">\n  <div class=\"catalog-wrapper\">\n    {% assign pdf_url = \"https://cdn.shopify.com/s/files/1/0422/5397/5709/files/Bastelkatalog_Ostern.pdf?v=1773243261\" %}\n    \n    <iframe src=\"https://docs.google.com/viewer?url={{ pdf_url | url_encode }}&embedded=true\" loading=\"lazy\">\n    </iframe>\n  </div>\n</div>\n\n<div class=\"catalog-download\">\n  <a href=\"{{ pdf_url }}\" target=\"_blank\" download>\n    PDF HERUNTERLADEN\n  </a>\n</div>\n\n<style>\n/* 1. The Outer Container - Centers everything */\n.catalog-tight-container {\n  width: 100%;\n  display: flex;\n  justify-content: center;\n  padding: 20px 0;\n  background-color: transparent;\n}\n\n/* 2. The Wrapper - This is where we force the shape */\n.catalog-wrapper {\n  /* This width/height combo creates a vertical 'A4' ratio */\n  width: 750px; \n  height: 1050px;\n  max-width: 95%; /* Prevents overflow on smaller screens */\n  background: #fff;\n  box-shadow: 0 10px 40px rgba(0,0,0,0.15);\n  border: 1px solid #ddd;\n  overflow: hidden;\n}\n\n.catalog-wrapper iframe {\n  width: 100%;\n  height: 100%;\n  border: none;\n}\n\n/* 3. Button Styling */\n.catalog-download {\n  text-align: center;\n  padding: 30px 0;\n}\n\n.catalog-download a {\n  background: #333;\n  color: #fff;\n  padding: 12px 30px;\n  text-decoration: none;\n  font-family: sans-serif;\n  font-weight: bold;\n  letter-spacing: 1px;\n  border-radius: 2px;\n}\n\n/* 4. Responsive tweak for smaller laptops/tablets */\n@media screen and (max-width: 1024px) {\n  .catalog-wrapper {\n    width: 600px;\n    height: 850px;\n  }\n}\n\n/* 5. Mobile Fix */\n@media screen and (max-width: 768px) {\n  .catalog-wrapper {\n    width: 100%;\n    height: 650px;\n  }\n}\n</style>"
