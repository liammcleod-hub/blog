              "name": "t:names.custom_liquid",
              "settings": {
                "custom_liquid": "{%- assign col = collection -%}\n{%- assign cat = col.metafields.custom.category.value -%}\n{%- if cat -%}\n  {%- comment %}Build full chain up to root{%- endcomment -%}\n  {%- assign chain = '' | split: '' -%}\n  {%- assign node = cat -%}\n  {%- for i in (1..20) -%}\n    {%- assign chain = chain | push: node -%}\n    {%- if node.parent -%}\n      {%- assign node = node.parent.value -%}\n    {%- else -%}\n      {%- break -%}\n    {%- endif -%}\n  {%- endfor -%}\n  {%- assign chain = chain | reverse -%}\n\n  <nav class=\"c-breadcrumbs\" aria-label=\"Breadcrumb\">\n    <a href=\"{{ routes.root_url }}\">Home</a>\n\n    {%- for n in chain -%}\n      {%- comment %}\n        Use the first attached collection on each category as the link target.\n        IMPORTANT: use the Liquid filter | first (not .first) because this is an array.\n      {%- endcomment -%}\n      {%- assign n_cols = n.collections.value -%}\n      {%- assign n_col = n_cols | first -%}\n      {%- if n_col -%}\n        <span aria-hidden=\"true\">/</span>\n        <a href=\"{{ n_col.url }}\">{{ n.title }}</a>\n      {%- else -%}\n        {%- comment %}If no collection is attached, render the label without link{%- endcomment -%}\n        <span aria-hidden=\"true\">/</span>\n        <span>{{ n.title }}</span>\n      {%- endif -%}\n    {%- endfor -%}\n\n    <span aria-hidden=\"true\">/</span>\n    <span>{{ col.title }}</span>\n  </nav>\n\n  <style>\n    .c-breadcrumbs { font-size:14px; line-height:1.4 }\n    .c-breadcrumbs a { text-decoration:none }\n    .c-breadcrumbs a:hover { text-decoration:underline }\n    .c-breadcrumbs span[aria-hidden=\"true\"] { margin: 0 6px }\n  </style>\n{%- endif -%}"
