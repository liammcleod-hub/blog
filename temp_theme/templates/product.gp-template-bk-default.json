                    "custom_liquid_EkRxpR": {
                      "blocks": {},
                      "disabled": true,
                      "name": "t:names.custom_liquid",
                      "settings": {
                        "custom_liquid": "<div class=\"special-extras-bonus\">\n  <div class=\"special-extras-header\">Extra für dich</div>\n  <div class=\"special-extras-text\">\n    Je nach Umfang deiner Bestellung erscheint unten ein kleines Extra, das du auswählen kannst.\n</div>\n\n<style>\n.special-extras-bonus {\n  background: linear-gradient(90deg, #f9efe9 80%, #ffe3ec 100%);\n  border: 1px solid #912E38;\n  border-radius: 6px;\n  padding: 18px 12px;\n  margin-top: 20px;\n  margin-bottom: 20px;\n  box-shadow: 0 2px 8px rgba(145,46,56,0.13);\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n}\n\n.special-extras-header {\n  font-size: 1.15rem;\n  font-weight: bold;\n  color: #912E38;\n  margin-bottom: 8px;\n}\n\n.special-extras-text {\n  font-size: 0.94rem;\n  color: #3c2730;\n  margin-bottom: 8px;\n}\n\n\n\n@media (max-width: 650px) {\n  .special-extras-bonus { padding: 14px 6px; }\n  .special-extras-header, .special-extras-sale { font-size: 1rem; }\n}\n</style>"
                      },
                      "type": "custom-liquid"
                    },
