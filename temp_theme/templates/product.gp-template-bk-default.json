                    "custom_liquid_nBtW3D": {
                      "blocks": {},
                      "disabled": true,
                      "name": "t:names.custom_liquid",
                      "settings": {
                        "custom_liquid": "<style>\n.herbst-discount-banner {\n  border: 2px solid #d7af67;\n  background: #fffbe1;\n  border-radius: 10px;\n  padding: 18px 15px;\n  max-width: 380px;\n  margin: 24px auto;\n  font-family: 'Inter', Arial, sans-serif;\n  box-shadow: 0 2px 7px rgba(215, 175, 103, 0.1);\n  text-align: center;\n}\n.herbst-discount-banner .promo-title {\n  font-size: 1.1em;\n  font-weight: bold;\n  color: #e67e22;\n  margin-bottom: 7px;\n}\n.herbst-discount-banner .promo-details {\n  font-size: 1em;\n  color: #333;\n  margin-bottom: 7px;\n}\n.herbst-discount-banner .promo-percent {\n  font-size: 1.18em;\n  font-weight: bold;\n  color: #76a819;\n  background: #f2f5d5;\n  padding: 4px 15px;\n  border-radius: 7px;\n  display: inline-block;\n  margin-top: 8px;\n  margin-bottom: 2px;\n  letter-spacing: 0.04em;\n}\n.herbst-discount-banner .how-to {\n  font-size: 0.95em;\n  color: #e67e22;\n  margin-top: 7px;\n  font-style: italic;\n}\n</style>\n<div class=\"herbst-discount-banner\">\n  <div class=\"promo-title\">HERBST-Special: Spare jetzt <span class=\"promo-percent\">10%</span> auf deine Bestellung!</div>\n  <div class=\"promo-details\">Nutze den Rabattcode:</div>\n  <div class=\"promo-percent\">HERBST</div>\n  <div class=\"how-to\">Einfach an der Kasse eingeben & Vorteil sichern!</div>\n</div>"
                      },
                      "type": "custom-liquid"
                    },
                    "custom_liquid_znwcY6": {
                      "blocks": {},
                      "disabled": true,
                      "name": "t:names.custom_liquid",
                      "settings": {
                        "custom_liquid": "<div class=\"bastelschachtel-product-banner align-left\">\n    <strong>Weihnachts-Rabatt: 10% mit Code WINTER10</strong>\n    <span class=\"promo-code\">Code: WINTER10</span>\n</div>  \n    \n<style>    \n    .bastelschachtel-product-banner.align-left {\n  width: 100%;\n  text-align: left;\n  background: linear-gradient(135deg, #fce6e0 0%, #fff8f5 100%);\n  color: #5a3a38;\n  border-left: 4px solid #a67c7a;\n  border-radius: 3px;\n  padding: 12px 16px;\n  font-size: 1rem;\n  font-weight: 500;\n  margin-top: 8px;\n  letter-spacing: .3px;\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  flex-wrap: wrap;\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n}\n\n.bastelschachtel-product-banner strong {\n  font-weight: 600;\n  color: #5a3a38;\n}\n\n.bastelschachtel-product-banner .promo-code {\n  background: #d9c3ba;\n  color: #fff;\n  border-radius: 2px;\n  padding: 4px 10px;\n  font-weight: bold;\n  font-size: 0.9rem;\n  font-family: 'Courier New', monospace;\n}\n\n@media (max-width: 650px) {\n  .bastelschachtel-product-banner { \n    padding: 10px 12px; \n    font-size: 0.95rem;\n  }\n  .bastelschachtel-product-banner .promo-code { font-size: 0.85rem; }\n}\n</style>"
                      },
                      "type": "custom-liquid"
