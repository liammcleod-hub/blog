        "custom_liquid_VDq6fT": {
          "type": "custom-liquid",
          "name": "t:names.custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n  #clear-cart-btn {\n    background-color: #8B3A3A;\n    color: white;\n    border: 2px solid #8B3A3A;\n    border-radius: 4px;\n    padding: 12px 24px;\n    font-size: 16px;\n    cursor: pointer;\n    font-weight: 600;\n    display: none;\n    margin-top: 16px;\n  }\n  \n  #clear-cart-btn.show {\n    display: inline-block;\n  }\n  \n  #clear-cart-btn:hover {\n    background-color: #6B2B2B;\n    border-color: #6B2B2B;\n  }\n</style>\n\n<button id=\"clear-cart-btn\">Warenkorb leeren</button>\n\n<script>\n  function initClearCartButton() {\n    // Fetch cart data from Shopify's cart API\n    fetch('/cart.js')\n      .then((response) => response.json())\n      .then((cart) => {\n        const btn = document.getElementById('clear-cart-btn');\n        if (cart.item_count > 0) {\n          btn.classList.add('show');\n        } else {\n          btn.classList.remove('show');\n        }\n      })\n      .catch((error) => {\n        console.error('Error fetching cart:', error);\n        // Fallback: check document title or cart counter\n        const cartBtn = document.getElementById('clear-cart-btn');\n        if (cartBtn) {\n          cartBtn.classList.add('show');\n        }\n      });\n  }\n  \n  function clearCart() {\n    fetch('/cart/clear.js', { method: 'POST' })\n      .then(() => { location.reload(); })\n      .catch((error) => { \n        console.error('Error clearing cart:', error);\n        alert('Fehler beim Leeren des Warenkorbs. Bitte versuchen Sie es erneut.');\n      });\n  }\n  \n  // Initialize button and add event listener\n  const clearBtn = document.getElementById('clear-cart-btn');\n  if (clearBtn) {\n    clearBtn.addEventListener('click', clearCart);\n    initClearCartButton();\n  }\n  \n  // Listen for cart updates (e.g., when items are added/removed)\n  document.addEventListener('cart:update', initClearCartButton);\n</script>"
          },
