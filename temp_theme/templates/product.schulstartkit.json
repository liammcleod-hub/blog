              },
              "blocks": {
                "custom_liquid_rqR48p": {
                  "type": "custom-liquid",
                  "name": "t:names.custom_liquid",
                  "settings": {
                    "custom_liquid": "<style>\n/* Add your custom styles for the delivery estimate section here */\n.delivery-estimate {\n  text-align: center; /* This will center the text inside this div */\n\n  /* Example: margin-top: 20px; */\n  /* Example: padding: 15px; */\n  /* Example: background-color: #f9f9f9; */\n  /* Example: border: 1px solid #ddd; */\n  /* Example: border-radius: 5px; */\n  /* Example: box-shadow: 0 2px 5px rgba(0,0,0,0.1); */\n}\n\n/* Styles for the delivery text itself (the dates) */\n.delivery-estimate .delivery-text {\n  font-size: 0.85em;\n  /* Make characters closer */\n  letter-spacing: -0.03em; /* Adjust this value (e.g., -0.01em to -0.05em) as needed */\n  /* Make font slightly thinner */\n  font-weight: 100; /* '300' is typically 'light'. '400' is 'normal'. 'lighter' also works. */\n\n  /* Other properties you might add: */\n  /* color: rgba(51, 51, 51, 0.8); */\n  /* margin: 0; */\n  /* line-height: 1.5; */\n}\n\n/* Styles for the bold and italic \"Lieferung rechtzeitig bis zum Schulstart:\" part */\n.delivery-estimate .delivery-text strong em {\n  /* Make characters closer */\n  letter-spacing: -0.03em; /* Can be slightly more aggressive for bold text */\n  /* Make font slightly thinner than default bold */\n  font-weight: 300; /* '300' is typically 'medium'. '700' is default bold. */\n\n  /* Other properties you might add: */\n  /* color: red; */\n  /* opacity: 0.8; */\n}\n</style>\n\n<div class=\"delivery-estimate\">\n  {% comment %}\n    Calculates and displays an estimated delivery date range.\n    Adds 3-5 days to today's date, with German weekday translation.\n  {% endcomment %}\n\n  {% assign delivery_start_offset_days = 3 %}\n  {% assign delivery_end_offset_days = 5 %}\n  {% assign seconds_in_a_day = 24 | times: 60 | times: 60 %}\n\n  {% comment %} Get current timestamp for calculation {% endcomment %}\n  {% assign current_timestamp = 'now' | date: '%s' %}\n\n  {% comment %} Calculate start date timestamp {% endcomment %}\n  {% assign start_seconds_to_add = delivery_start_offset_days | times: seconds_in_a_day %}\n  {% assign delivery_start_timestamp = current_timestamp | plus: start_seconds_to_add %}\n\n  {% comment %} Directly format start weekday and date from the timestamp {% endcomment %}\n  {% assign start_weekday_en = delivery_start_timestamp | date: '%A' %}\n  {% assign start_day_month_year = delivery_start_timestamp | date: '%d.%m.%Y' %}\n\n  {% comment %} Translate start weekday to German {% endcomment %}\n  {% assign start_weekday_de = '' %}\n  {% case start_weekday_en %}\n    {% when 'Monday' %}{% assign start_weekday_de = 'Montag' %}\n    {% when 'Tuesday' %}{% assign start_weekday_de = 'Dienstag' %}\n    {% when 'Wednesday' %}{% assign start_weekday_de = 'Mittwoch' %}\n    {% when 'Thursday' %}{% assign start_weekday_de = 'Donnerstag' %}\n    {% when 'Friday' %}{% assign start_weekday_de = 'Freitag' %}\n    {% when 'Saturday' %}{% assign start_weekday_de = 'Samstag' %}\n    {% when 'Sunday' %}{% assign start_weekday_de = 'Sonntag' %}\n  {% endcase %}\n\n  {% comment %} Calculate end date timestamp {% endcomment %}\n  {% assign end_seconds_to_add = delivery_end_offset_days | times: seconds_in_a_day %}\n  {% assign delivery_end_timestamp = current_timestamp | plus: end_seconds_to_add %}\n\n  {% comment %} Directly format end weekday and date from the timestamp {% endcomment %}\n  {% assign end_weekday_en = delivery_end_timestamp | date: '%A' %}\n  {% assign end_day_month_year = delivery_end_timestamp | date: '%d.%m.%Y' %}\n\n  {% comment %} Translate end weekday to German {% endcomment %}\n  {% assign end_weekday_de = '' %}\n  {% case end_weekday_en %}\n    {% when 'Monday' %}{% assign end_weekday_de = 'Montag' %}\n    {% when 'Tuesday' %}{% assign end_weekday_de = 'Dienstag' %}\n    {% when 'Wednesday' %}{% assign end_weekday_de = 'Mittwoch' %}\n    {% when 'Thursday' %}{% assign end_weekday_de = 'Donnerstag' %}\n    {% when 'Friday' %}{% assign end_weekday_de = 'Freitag' %}\n    {% when 'Saturday' %}{% assign end_weekday_de = 'Samstag' %}\n    {% when 'Sunday' %}{% assign end_weekday_de = 'Sonntag' %}\n  {% endcase %}\n\n  <p class=\"delivery-text\">\n    <strong>Lieferung rechtzeitig bis zum Schulstart:</strong> {{ start_weekday_de }}, {{ start_day_month_year }} - {{ end_weekday_de }}, {{ end_day_month_year }}\n  </p>\n</div>"
                  },
                  "blocks": {}
                }
              },
