            "text_n4yqRd": {
              "type": "text",
              "name": "t:names.text",
              "settings": {
                "text": "<p>Unser Sortiment wurde von erfahrenen Bastel- und DIY-Experten sorgfältig zusammengestellt. </p>",
                "width": "fit-content",
                "max_width": "normal",
                "alignment": "left",
