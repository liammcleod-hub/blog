                      "settings": {
                        "custom_liquid": "<style type=\"text/css\">\n.tg {border-collapse:collapse;border-spacing:0;}\n.tg td{border-color:black;border-style:solid;border-width:1px;font-family:Arial, sans-serif;font-size:14px;\n overflow:hidden;padding:10px 5px;word-break:normal;}\n.tg th{border-color:black;border-style:solid;border-width:1px;font-family:Arial, sans-serif;font-size:14px;\n font-weight:normal;overflow:hidden;padding:10px 5px;word-break:normal;}\n.tg .tg-0lax{text-align:left;vertical-align:top}\n.tg .tg-arkd{background-color:#F1EFE7;color:rgba(0, 0, 0, 0.81);text-align:left;vertical-align:top}\n.tg .tg-4yl7{background-color:#F1EFE7;color:rgba(0, 0, 0, 0.81);text-align:center;vertical-align:top}\n.tg .tg-group-head {font-weight:bold; background-color:#E8E4D9; text-align:left; vertical-align:top;}\n</style>\n<table class=\"tg\"><thead>\n  <tr>\n    <th class=\"tg-0lax\">Land</th>\n    <th class=\"tg-0lax\">Versandkosten</th>\n    <th class=\"tg-0lax\">Gratis ab</th>\n  </tr></thead>\n<tbody>\n  <tr>\n    <td class=\"tg-group-head\" colspan=\"3\">Österreich & Deutschland</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Österreich (GLS)</td>\n    <td class=\"tg-4yl7\">€6,94</td>\n    <td class=\"tg-4yl7\">€70</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Belgien (GLS)</td>\n    <td class=\"tg-4yl7\">€7,70</td>\n    <td class=\"tg-4yl7\">€110</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Deutschland (GLS)</td>\n    <td class=\"tg-4yl7\">€7,95</td>\n    <td class=\"tg-4yl7\">€70</td>\n  </tr>\n\n  <tr>\n    <td class=\"tg-group-head\" colspan=\"3\">Mittel-/Osteuropa (€11,80)</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Ungarn, Slowenien (GLS)</td>\n    <td class=\"tg-4yl7\">€11,80</td>\n    <td class=\"tg-4yl7\">€110</td>\n  </tr>\n\n  <tr>\n    <td class=\"tg-group-head\" colspan=\"3\">Nachbarländer (€12,96)</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Luxemburg, Polen, Slowakei,<br>Tschechien (GLS)</td>\n    <td class=\"tg-4yl7\">€12,96</td>\n    <td class=\"tg-4yl7\">€110</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Italien (GLS)</td>\n    <td class=\"tg-4yl7\">€12,96</td>\n    <td class=\"tg-4yl7\">€110</td>\n  </tr>\n\n  <tr>\n    <td class=\"tg-group-head\" colspan=\"3\">Nord-, Süd- & Osteuropa (€17,76)</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Dänemark, Niederlande (GLS)</td>\n    <td class=\"tg-4yl7\">€17,76</td>\n    <td class=\"tg-4yl7\">€110*</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Finnland, Schweden (GLS)</td>\n    <td class=\"tg-4yl7\">€17,76</td>\n    <td class=\"tg-4yl7\">€150</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Estland, Lettland, Litauen (GLS)</td>\n    <td class=\"tg-4yl7\">€17,76</td>\n    <td class=\"tg-4yl7\">€150</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Frankreich, Griechenland, Kroatien,<br>Portugal, Malta (GLS)</td>\n    <td class=\"tg-4yl7\">€17,76</td>\n    <td class=\"tg-4yl7\">€150</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Spanien (GLS)</td>\n    <td class=\"tg-4yl7\">€17,96</td>\n    <td class=\"tg-4yl7\">€150</td>\n  </tr>\n\n  <tr>\n    <td class=\"tg-group-head\" colspan=\"3\">Spezial (Nicht-EU/EFTA)</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Liechtenstein</td>\n    <td class=\"tg-4yl7\">€19,80</td>\n    <td class=\"tg-4yl7\">€160</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Großbritannien</td>\n    <td class=\"tg-4yl7\">€26,99</td>\n    <td class=\"tg-4yl7\">€160</td>\n  </tr>\n  <tr>\n    <td class=\"tg-arkd\">Schweiz</td>\n    <td class=\"tg-4yl7\">€42,99</td>\n    <td class=\"tg-4yl7\">-</td>\n  </tr>\n</tbody></table>"
