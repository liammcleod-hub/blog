        "accordion_UNyxac": {
          "type": "accordion",
          "name": "t:names.accordion",
          "settings": {
            "icon": "plus",
            "dividers": true,
            "type_preset": "h5",
            "inherit_color_scheme": true,
            "color_scheme": "",
            "border": "none",
            "border_width": 1,
