    "section_RfWH9a": {
      "type": "section",
      "blocks": {
        "text_idjkcz": {
          "type": "text",
          "name": "t:names.heading",
          "settings": {
            "text": "<h2>Häufig gestellte Fragen</h2>",
            "width": "fit-content",
            "max_width": "narrow",
            "alignment": "left",
