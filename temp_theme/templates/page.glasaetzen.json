              ]
            },
            "accordion_row_JHkt8W": {
              "type": "_accordion-row",
              "settings": {
                "heading": "Wie schnell ist der Versand?",
                "open_by_default": false,
                "icon": "none",
                "width": 20
              },
              "blocks": {
                "text_rN8TGe": {
                  "type": "text",
                  "name": "t:names.text",
                  "settings": {
                    "text": "<p>Innerhalb Österreichs liefern wir in der Regel innerhalb von 1 bis 3 Werktagen nach Bestelleingang. Für Lieferungen nach Deutschland rechnen wir mit 3 bis 5 Werktagen. Ab einem Bestellwert von 70 € versenden wir für dich versandkostenfrei – egal ob nach Österreich oder Deutschland.</p>",
