            "padding-inline-end": 0
          },
          "blocks": {}
        },
        "custom_liquid_mKrHpe": {
          "type": "custom-liquid",
          "name": "t:names.custom_liquid",
          "settings": {
            "custom_liquid": "<ul class=\"bs-trust-list\">\n  <li>Kuratiert von Kreativen mit 30+ Jahren Erfahrung – nur Materialien, die im echten Bastelalltag bestehen.</li>\n  <li>Lokaler Österreich-Service &amp; schneller Versand: GLS &amp; Post, ab 70 € versandkostenfrei nach AT &amp; DE.</li>\n  <li>Direkter Draht bei Fragen: E-Mail, WhatsApp &amp; persönlicher Support vom Bastelschachtel-Team.</li>\n  <li>Über 50.000 kreative Kund:innen und hunderte Bewertungen mit Top-Sternen – du bist in guter Gesellschaft.</li>\n</ul>\n\n<style>\n  .bs-trust-list {\n    padding-left: 1.2rem;\n    margin: 0;\n    list-style: disc;\n  }\n  .bs-trust-list li {\n    margin-bottom: 0.75rem; /* Abstand zwischen Bulletpoints */\n  }\n  .bs-trust-list li:last-child {\n    margin-bottom: 0;\n  }\n</style>"
          },
          "blocks": {}
        },
        "custom_liquid_mixeXx": {
          "type": "custom-liquid",
          "name": "t:names.custom_liquid",
          "settings": {
            "custom_liquid": "<section class=\"bs-micro-social-proof\" aria-label=\"Bastelschachtel Social Proof\">\n  <p class=\"bs-micro-social-proof__text\">\n    Mehr als 50.000 Kund:innen, 250.000+ Projekte und tausende Produktbewertungen – Bastelschachtel begleitet dich von der Idee bis zum fertigen Glas.\n  </p>\n</section>\n\n<style>\n  .bs-micro-social-proof {\n    background-color: #912e38; /* kräftiges, aber nicht zu grelles Rot für guten Kontrast */\n    color: #ffffff;\n    border-radius: 8px;\n    padding: 12px 16px;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    text-align: center;\n    max-width: 100%;\n    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.18);\n    font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n  }\n\n  .bs-micro-social-proof__text {\n    margin: 0;\n    font-size: 0.95rem;\n    line-height: 1.4;\n    font-weight: 600;\n  }\n\n  @media (min-width: 768px) {\n    .bs-micro-social-proof {\n      padding: 14px 20px;\n    }\n    .bs-micro-social-proof__text {\n      font-size: 1rem;\n    }\n  }\n</style>"
          },
          "blocks": {}
