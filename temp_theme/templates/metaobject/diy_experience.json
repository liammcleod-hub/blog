                    "custom_liquid_steps_grid": {
                      "type": "custom-liquid",
                      "settings": {
                        "custom_liquid": "<div id=\"diy-steps-{{ block.id }}\" class=\"diy-steps\">\n  <div id=\"diy-steps-anchor\" style=\"scroll-margin-top: 120px;\"></div>\n\n  <style>\n    #diy-steps-{{ block.id }} .diy-steps__grid {\n      display: grid;\n      grid-template-columns: repeat(4, minmax(0, 1fr));\n      gap: 24px;\n    }\n\n    @media (max-width: 990px) {\n      #diy-steps-{{ block.id }} .diy-steps__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }\n    }\n\n    @media (max-width: 640px) {\n      #diy-steps-{{ block.id }} .diy-steps__grid { grid-template-columns: 1fr; }\n    }\n\n    #diy-steps-{{ block.id }} .diy-steps__card {\n      border: 1px solid #eee;\n      border-radius: 12px;\n      padding: 18px;\n      background: #fff;\n    }\\n    #diy-steps-{{ block.id }} .diy-steps__title {\n      margin: 0 0 12px;\n      font-weight: 700;\n      line-height: 1.25;\n    }#diy-steps-{{ block.id }} .diy-steps__image {\n      aspect-ratio: 1 / 1;\n      overflow: hidden;\n      border-radius: 10px;\n      background: #f4f4f4;\n      margin: 0 0 12px;\n    }\n\n    #diy-steps-{{ block.id }} .diy-steps__image img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      display: block;\n    }\n\n    #diy-steps-{{ block.id }} .diy-steps__desc {\n      margin: 0;\n    }\n  </style>\n\n  {%- assign steps = metaobject.steps.value -%}\n  {%- if steps and steps.size > 0 -%}\n    <div class=\"diy-steps__grid\">\n      {%- assign emitted = 0 -%}\n      {%- for step in steps -%}\n        {%- assign s_image = step.image | default: step.step_image -%}\n        {%- if s_image == blank -%}\n          {%- continue -%}\n        {%- endif -%}\n\n        {%- assign emitted = emitted | plus: 1 -%}\n        {%- if emitted > 8 -%}\n          {%- break -%}\n        {%- endif -%}\n\n        <article class=\"diy-steps__card\">\n          <h3 class=\"diy-steps__title h3\">{{ step.title | default: step.step_title }}</h3>\n\n          <div class=\"diy-steps__image\">\n            {{ s_image | image_url: width: 900 | image_tag: loading: 'lazy' }}\n          </div>\n\n          <div class=\"diy-steps__desc rte\">{{ step.description | default: step.step_body | newline_to_br }}</div>\n        </article>\n      {%- endfor -%}\n    </div>\n  {%- endif -%}\n</div>"
