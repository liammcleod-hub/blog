              "blocks": {
                "custom_liquid_materials_grid": {
                  "type": "custom-liquid",
                  "settings": {
                    "custom_liquid": "<div id=\"diy-materials-{{ block.id }}\" class=\"diy-materials\">\n  <style>\n    #diy-materials-{{ block.id }} .diy-materials__grid {\n      display: grid;\n      grid-template-columns: repeat(auto-fit, minmax(220px, 220px));\n      justify-content: center;\n      gap: 20px;\n      max-width: calc(4 * 220px + 3 * 20px);\n      margin-left: auto;\n      margin-right: auto;\n    }\n\n    @media (max-width: 990px) {\n      #diy-materials-{{ block.id }} .diy-materials__grid {\n        grid-template-columns: repeat(auto-fit, minmax(220px, 220px));\n        max-width: calc(2 * 220px + 1 * 20px);\n        margin-left: auto;\n        margin-right: auto;\n      }\n    }\n\n    @media (max-width: 640px) {\n      #diy-materials-{{ block.id }} .diy-materials__grid {\n        grid-template-columns: 1fr;\n      }\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__card {\n      border: 1px solid #eee;\n      border-radius: 12px;\n      padding: 14px;\n      background: #fff;\n      display: grid;\n      grid-template-rows: auto auto auto;\n      gap: 10px;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__top {\n      display: grid;\n      grid-template-columns: 1fr;\n      gap: 10px;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__link {\n      display: block;\n      text-decoration: none;\n      color: inherit;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__image {\n      aspect-ratio: 1 / 1;\n      overflow: hidden;\n      border-radius: 10px;\n      background: #f4f4f4;\n      margin: 0 0 10px;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__image img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      display: block;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__title {\n      margin: 0 0 6px;\n      font-weight: 700;\n      line-height: 1.25;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__price {\n      margin: 0;\n      font-weight: 700;\n      color: #912e38;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__controls {\n      display: grid;\n      gap: 10px;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__row {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 10px;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__select {\n      width: 100%;\n      padding: 10px 12px;\n      border: 1px solid #ddd;\n      border-radius: 10px;\n      background: #fff;\n    }\n\n    #diy-materials-{{ block.id }} .diy-qty {\n      display: inline-flex;\n      align-items: center;\n      border: 1px solid #ddd;\n      border-radius: 10px;\n      overflow: hidden;\n      background: #fff;\n    }\n\n    #diy-materials-{{ block.id }} .diy-qty button {\n      width: 36px;\n      height: 36px;\n      border: 0;\n      background: transparent;\n      cursor: pointer;\n      font-size: 18px;\n      line-height: 1;\n    }\n\n    #diy-materials-{{ block.id }} .diy-qty input {\n      width: 46px;\n      height: 36px;\n      border: 0;\n      text-align: center;\n      font-weight: 700;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__footer {\n      margin-top: 18px;\n      display: flex;\n      justify-content: center;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__add {\n      background: #912e38;\n      color: #fff;\n      border: 0;\n      border-radius: 12px;\n      padding: 12px 18px;\n      font-weight: 800;\n      cursor: pointer;\n    }\n\n    #diy-materials-{{ block.id }} .diy-materials__add:disabled {\n      opacity: 0.6;\n      cursor: not-allowed;\n    }\n  </style>\n\n  {%- assign materials = metaobject.materials_products.value | default: metaobject.materials_list.value -%}\n  {%- if materials and materials.size > 0 -%}\n    <div class=\"diy-materials__grid\" data-materials-grid>\n      {%- for product in materials -%}\n        {%- if product == blank -%}{%- continue -%}{%- endif -%}\n        {%- assign default_variant = product.selected_or_first_available_variant | default: product.first_available_variant | default: product.variants.first -%}\n\n        <div class=\"diy-materials__card\" data-product-card>\n          <div class=\"diy-materials__top\">\n            <label class=\"diy-materials__row\">\n              <span style=\"font-weight:700;\">Ausw&auml;hlen</span>\n              <input type=\"checkbox\" checked data-material-select>\n            </label>\n\n            <a class=\"diy-materials__link\" href=\"{{ product.url }}\">\n              <div class=\"diy-materials__image\">\n                {%- if product.featured_image -%}\n                  {{ product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}\n                {%- endif -%}\n              </div>\n              <p class=\"diy-materials__title\">{{ product.title }}</p>\n              {%- if default_variant -%}\n                <p class=\"diy-materials__price\" data-price>{{ default_variant.price | money }}</p>\n              {%- endif -%}\n            </a>\n          </div>\n\n          <div class=\"diy-materials__controls\">\n            {%- if product.variants.size > 1 -%}\n              <select class=\"diy-materials__select\" data-variant-select>\n                {%- for v in product.variants -%}\n                  <option value=\"{{ v.id }}\" data-price=\"{{ v.price }}\" {% if v == default_variant %}selected{% endif %} {% unless v.available %}disabled{% endunless %}>\n                    {{ v.title }} - {{ v.price | money }}\n                  </option>\n                {%- endfor -%}\n              </select>\n            {%- else -%}\n              {%- if default_variant -%}\n                <input type=\"hidden\" value=\"{{ default_variant.id }}\" data-variant-select>\n              {%- endif -%}\n            {%- endif -%}\n\n            <div class=\"diy-materials__row\">\n              <span style=\"font-weight:700;\">Menge</span>\n              <div class=\"diy-qty\" data-qty>\n                <button type=\"button\" aria-label=\"Minus\" data-qty-minus>-</button>\n                <input type=\"number\" min=\"0\" value=\"1\" inputmode=\"numeric\" data-qty-input>\n                <button type=\"button\" aria-label=\"Plus\" data-qty-plus>+</button>\n              </div>\n            </div>\n          </div>\n        </div>\n      {%- endfor -%}\n    </div>\n\n    <div class=\"diy-materials__footer\">\n      <button class=\"diy-materials__add\" type=\"button\" data-add-selected>Ausgew&auml;hlte in den Warenkorb</button>\n    </div>\n\n    <script>\n      (function(){\n        const root = document.getElementById('diy-materials-{{ block.id }}');\n        if (!root) return;\n\n        function updatePrice(card){\n          const priceEl = card.querySelector('[data-price]');\n          const variantEl = card.querySelector('[data-variant-select]');\n          if (!priceEl || !variantEl) return;\n          const opt = variantEl.tagName === 'SELECT' ? variantEl.options[variantEl.selectedIndex] : null;\n          const priceCents = opt ? opt.getAttribute('data-price') : null;\n          if (!priceCents) return;\n          const cents = parseInt(priceCents, 10);\n          if (Number.isNaN(cents)) return;\n          priceEl.textContent = (cents/100).toLocaleString('de-DE', { style: 'currency', currency: 'EUR' });\n        }\n\n        root.querySelectorAll('[data-product-card]').forEach(card => {\n          const minus = card.querySelector('[data-qty-minus]');\n          const plus = card.querySelector('[data-qty-plus]');\n          const input = card.querySelector('[data-qty-input]');\n          const variant = card.querySelector('[data-variant-select]');\n\n          if (minus && input) minus.addEventListener('click', () => { input.value = Math.max(0, (parseInt(input.value||'0',10)||0) - 1); });\n          if (plus && input) plus.addEventListener('click', () => { input.value = (parseInt(input.value||'0',10)||0) + 1; });\n          if (variant && variant.tagName === 'SELECT') variant.addEventListener('change', () => updatePrice(card));\n          updatePrice(card);\n        });\n\n        const btn = root.querySelector('[data-add-selected]');\n        if (!btn) return;\n\n        btn.addEventListener('click', async () => {\n          const items = [];\n          root.querySelectorAll('[data-product-card]').forEach(card => {\n            const checked = card.querySelector('[data-material-select]')?.checked;\n            if (!checked) return;\n            const variantEl = card.querySelector('[data-variant-select]');\n            const qty = parseInt(card.querySelector('[data-qty-input]')?.value || '0', 10) || 0;\n            if (!variantEl || qty <= 0) return;\n            const id = variantEl.tagName === 'SELECT' ? variantEl.value : variantEl.value;\n            items.push({ id, quantity: qty });\n          });\n\n          if (!items.length) return;\n          btn.disabled = true;\n          const prev = btn.textContent;\n          btn.textContent = 'Wird hinzugef?gt...';\n\n          try {\n            await fetch('/cart/add.js', {\n              method: 'POST',\n              headers: { 'Content-Type': 'application/json' },\n              body: JSON.stringify({ items })\n            });\n            window.location.href = '/cart';\n          } catch(e) {\n            btn.disabled = false;\n            btn.textContent = prev;\n          }\n        });\n      })();\n    </script>\n  {%- endif -%}\n</div>"
                  },
                  "blocks": {}
                }
              },
