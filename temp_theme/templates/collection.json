                "custom_liquid_JBEgML": {
                  "type": "custom-liquid",
                  "name": "t:names.custom_liquid",
                  "settings": {
                    "custom_liquid": "<style>\n  .inventory-status {\n    display: flex;\n    align-items: center;\n    gap: 6px;             /* Slightly tighter gap for a cleaner look */\n    font-size: 0.75rem;\n    line-height: 1;       /* Force line-height to 1 to kill extra vertical \"air\" */\n    margin: 0;            /* Reset all margins - control manually later if needed */\n    padding: 2px 0;       /* Tiny bit of padding just for visual balance */\n  }\n  \n  .status-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n    display: inline-block;\n    flex-shrink: 0;       /* Prevents the dot from squishing */\n    animation: blink-animation 1.5s infinite ease-in-out;\n  }\n\n  @keyframes blink-animation {\n    0% { opacity: 1; }\n    50% { opacity: 0.3; }\n    100% { opacity: 1; }\n  }\n</style>\n\n<div class=\"inventory-status\">\n  {% if closest.product.available %}\n    {% assign total_inventory = 0 %}\n    {% for variant in closest.product.variants %}\n      {% assign total_inventory = total_inventory | plus: variant.inventory_quantity %}\n    {% endfor %}\n\n    {% if total_inventory > 5 %}\n      <span class=\"status-dot\" style=\"background-color: #28a745;\"></span>\n      <span style=\"font-weight: 500; color: var(--color-foreground);\">{{ total_inventory }} Vorrätig</span>\n    \n    {% elsif total_inventory > 0 %}\n      <span class=\"status-dot\" style=\"background-color: #ffc107;\"></span>\n      <span style=\"font-weight: 500; color: #856404;\">Nur noch {{ total_inventory }} Stück</span>\n    \n    {% else %}\n      <span class=\"status-dot\" style=\"background-color: #dc3545;\"></span>\n      <span style=\"font-weight: 500; color: #dc3545;\">Momentan nicht verfügbar</span>\n    {% endif %}\n\n  {% else %}\n    <span class=\"status-dot\" style=\"background-color: #dc3545;\"></span>\n    <span style=\"font-weight: 500; color: #dc3545;\">Nicht vorrätig</span>\n  {% endif %}\n</div>"
