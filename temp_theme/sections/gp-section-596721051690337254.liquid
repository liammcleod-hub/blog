    color: var(--text-muted);
    margin-bottom: 20px;
}

/* ===== CONTAINER (ONLY THING WITH WIDTH LIMIT) ===== */
.container {
    max-width: var(--max-width);
    width: 100%;
    margin: 0 auto;
    padding: 0 20px;
}

/* ===== HEADER (FULL WIDTH) ===== */
.site-header {
    background: var(--primary);
    color: white;
    padding: 12px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
}

.logo {
    font-family: Georgia, serif;
    font-size: 12px;
    font-weight: 700;
    text-decoration: none;
    color: white;
    letter-spacing: 1px;
    white-space: nowrap;
}

.header-nav {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-left: auto;
}

.header-nav a {
    color: white;
    text-decoration: none;
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: opacity 0.2s;
    white-space: nowrap;
}

.header-nav a:hover {
    opacity: 0.8;
}

.btn-header {
    background: var(--accent);
    color: var(--text) !important;
    padding: 6px 10px;
    border-radius: 3px;
    font-size: 9px;
    white-space: nowrap;
    font-weight: 700;
}

@media (min-width: 768px) {
    .site-header {
        padding: 16px 20px;
        gap: 16px;
    }

    .logo {
        font-size: 14px;
    }

    .header-nav {
        gap: 12px;
    }

    .header-nav a {
        font-size: 11px;
    }

    .btn-header {
        padding: 8px 12px;
        font-size: 10px;
    }
}

/* ===== SECTIONS (REDUCED MOBILE PADDING) ===== */
.section-hero,
article section,
.section-disclaimer {
    padding: 20px 0;
}

/* Extra tight padding for hero on mobile */
.section-hero {
    padding: 12px 0;
}

@media (min-width: 768px) {
    .section-hero,
    article section,
    .section-disclaimer {
        padding: 32px 0;
    }
}

article section {
    border-bottom: 1px solid var(--border);
}

article h2 {
    margin-top: 0;
}

article p {
    font-size: 17px;
    line-height: 1.7;
}

/* ===== IMAGES ===== */
.hero-image,
.article-image {
    width: 100%;
    height: auto;
    display: block;
    margin: 16px 0;
    border-radius: 3px;
}

@media (min-width: 768px) {
    .hero-image,
    .article-image {
        margin: 32px 0;
    }
}

/* ===== CALLOUT BOX ===== */
.callout-block {
    background: rgba(145, 46, 56, 0.08);
    border-left: 4px solid var(--primary);
    padding: 20px;
    margin: 16px 0;
    border-radius: 3px;
}

@media (min-width: 768px) {
    .callout-block {
        margin: 32px 0;
    }
}

.callout-block p {
    margin-bottom: 0;
    font-style: italic;
    line-height: 1.7;
}

.callout-block strong {
    color: var(--primary);
}

/* ===== STEPS ===== */
.steps {
    margin: 16px 0;
}

@media (min-width: 768px) {
    .steps {
        margin: 32px 0;
    }
}

.step-item {
    background: #f9f7f5;
    padding: 20px;
    margin-bottom: 16px;
    border-left: 3px solid var(--accent);
    border-radius: 3px;
}

.step-label {
    font-size: 12px;
    color: var(--primary);
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 8px;
    letter-spacing: 1px;
}

.step-item h3 {
    font-size: 18px;
    margin-bottom: 8px;
    margin-top: 0;
}

.step-item p {
    font-size: 15px;
    line-height: 1.65;
    margin-bottom: 0;
    color: var(--text-muted);
}

/* ===== LISTS ===== */
.checklist {
    margin: 20px 0;
    padding-left: 30px;
    list-style: none;
}

.checklist li {
    margin-bottom: 12px;
    line-height: 1.65;
    position: relative;
    font-size: 17px;
}

.checklist li:before {
    content: "▪";
    color: var(--accent);
    font-weight: bold;
    position: absolute;
    left: -24px;
}

/* ===== TESTIMONIALS ===== */
.testimonial-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    margin: 32px 0;
}

.testimonial-card {
    background: #f9f7f5;
    padding: 20px;
    border-radius: 3px;
    border-top: 3px solid var(--primary);
}

.testimonial-quote {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 12px;
    color: var(--text);
    line-height: 1.4;
}

.testimonial-text {
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-muted);
    margin-bottom: 12px;
}

.testimonial-author {
    font-size: 12px;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* ===== CTA SECTION ===== */
.cta-section {
    text-align: center;
    padding: 40px 20px;
    background: #f9f7f5;
    margin: 32px 0;
    border-radius: 3px;
}

.cta-section h2 {
    border-bottom: none;
    padding-bottom: 0;
    margin-top: 0;
    margin-bottom: 20px;
}

.cta-text {
    font-size: 17px;
    line-height: 1.7;
    margin: 0 auto 20px;
    color: var(--text);
}

.cta-text p {
    margin-bottom: 16px;
}

.cta-text strong {
    display: block;
    margin-top: 12px;
    margin-bottom: 0;
}

.cta-subtext {
    color: var(--text-muted);
    font-size: 14px;
    margin: 20px 0;
    line-height: 1.6;
}

/* ===== BUTTONS ===== */
.btn-primary {
    display: inline-block;
    padding: 14px 24px;
    border-radius: 3px;
    background: var(--primary);
    color: white !important;
    font-weight: 700;
    font-size: 13px;
    text-decoration: none;
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: all 0.2s;
    border: none;
    cursor: pointer;
    margin: 16px 0;
    box-shadow: 0 2px 8px rgba(145, 46, 56, 0.15);
}

.btn-primary:hover {
    background: var(--primary-dark);
    box-shadow: 0 4px 16px rgba(145, 46, 56, 0.25);
    transform: translateY(-1px);
}

/* ===== DISCLAIMER ===== */
.section-disclaimer {
    background: #f0f0f0;
}

.disclaimer-text {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 12px;
}

/* ===== FOOTER (FULL WIDTH) ===== */
.site-footer {
    background: var(--text);
    color: white;
    padding: 32px 20px;
    margin-top: 32px;
}

.footer-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
}

.footer-col h4 {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
    color: white;
}

.footer-col a {
    display: block;
    margin-bottom: 8px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: 13px;
    transition: color 0.2s;
}

.footer-col a:hover {
    color: white;
}

.footer-bottom {
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.2);
    text-align: center;
    color: rgba(255, 255, 255, 0.6);
    font-size: 12px;
}

/* ===== TABLET (768px+) ===== */
@media (min-width: 768px) {
    h1 {
        font-size: 36px !important;
    }

    h2 {
        font-size: 28px !important;
    }

    .header-nav {
        gap: 20px;
    }

    .testimonial-grid {
        grid-template-columns: repeat(2, 1fr);
    }

    .footer-content {
        grid-template-columns: repeat(2, 1fr);
        gap: 32px;
    }
}

/* ===== DESKTOP (1024px+) ===== */
@media (min-width: 1024px) {
    h1 {
        font-size: 48px !important;
    }

    h2 {
        font-size: 32px !important;
    }

    .footer-content {
        grid-template-columns: repeat(4, 1fr);
        gap: 40px;
    }
}
