{% comment %}
  Glassmorphism Controls Section
  Provides CSS variables for button glassmorphism settings
{% endcomment %}

<style>
  :root {
    --glass-blur: {{ section.settings.blur_intensity }}px;
    --glass-gradient: linear-gradient(
      135deg,
      {{ section.settings.gradient_color_1 | color_modify: 'alpha', section.settings.bg_opacity | divided_by: 100.0 }},
      {{ section.settings.gradient_color_2 | color_modify: 'alpha', section.settings.bg_opacity | divided_by: 100.0 }}
    );
    --glass-border: {{ section.settings.border_color | color_modify: 'alpha', section.settings.border_opacity | divided_by: 100.0 }};
    --glass-speed: {{ section.settings.animation_speed }}s;
  }
</style>

{% schema %}
{
  "name": "Glassmorphism Controls",
  "settings": [
    {
      "type": "header",
      "content": "Blur & Transparency"
    },
    {
      "type": "range",
      "id": "blur_intensity",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "label": "Blur Intensity",
      "default": 15
    },
    {
      "type": "range",
      "id": "bg_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background Opacity",
      "default": 25
    },
    {
      "type": "range",
      "id": "border_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Border Opacity",
      "default": 40
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "min": 0,
      "max": 5,
      "step": 0.1,
      "unit": "s",
      "label": "Animation Speed",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "gradient_color_1",
      "label": "Gradient Color 1",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "gradient_color_2",
      "label": "Gradient Color 2",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Glassmorphism Controls"
    }
  ]
}
{% endschema %}
